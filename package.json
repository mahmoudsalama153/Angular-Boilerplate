{
  "name": "angularboilerplate",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "lint": "eslint . --cache --max-warnings 0",
    "lint:fix": "npm run lint -- --fix",
    "check:staged": "lint-staged --concurrent false"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21",
    "@angular/compiler": "^21",
    "@angular/core": "^21",
    "@angular/forms": "^21",
    "@angular/platform-browser": "^21",
    "@angular/router": "^21",
    "@ngrx/signals": "^21.0.1",
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/postcss": "^4.2.2",
    "husky": "^9.1.7",
    "postcss": "^8.5.8",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21",
    "@angular/cli": "^21",
    "@angular/compiler-cli": "^21",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*.{ts,html,js}": [
      "prettier --write",
      "eslint --cache --fix --max-warnings 0"
    ],
    "*.{scss,css,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
